# Copy this file to .env.work and fill in your values.
# .env.work is gitignored — never commit real credentials.

# Target hardware: rpi0 | rpi3 | rpi4 | rpi5
export MIX_TARGET=rpi5

# Immich server connection (can also be set via the web UI at runtime)
export IMMICH_URL=http://192.168.1.10:2283
export IMMICH_API_KEY=your_api_key_here
export IMMICH_ALBUM_ID=your_album_uuid_here

# Slide interval in milliseconds (default: 30000)
export SLIDE_INTERVAL_MS=30000

# Set to "true" to show the debug bar (photo index) on screen
export SHOW_DEBUG=false
